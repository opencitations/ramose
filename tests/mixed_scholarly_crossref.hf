#url /mixed
#type api
#base http://localhost:5000
#endpoint https://query-scholarly.wikidata.org/sparql
#engine sparql
#method get
#title Mixed Wikidata + OpenCitations + Crossref
#description Example RAMOSE operation combining SPARQL endpoints with SPARQL.ANYTHING
#version 0.0.1
#license ISC
#contacts test@example.org
#addon testaddon

#url /metadata/{dois}
#type operation
#dois str(\"?10\..+[^_\"]((__|\" \")10\..+[^_])*\"?)
#preprocess lower(dois) --> split_dois(dois)
#method get
#description Combined metadata from Wikidata, OpenCitations, and Crossref
#call /metadata/10.1108/jd-12-2013-0166__10.1038/nature12373
#field_type str(doi) str(qid) int(oc_citation_count) str(title) int(year)
#format xml,to_xml

#sparql  PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wd:  <http://www.wikidata.org/entity/>

SELECT DISTINCT ?doi ?qid
WHERE {
  VALUES ?doi { [[dois]] }
  BIND(UCASE(?doi) AS ?doi_norm)

  ?article wdt:P356 ?doi_norm .
  BIND(STRAFTER(str(?article), "http://www.wikidata.org/entity/") AS ?qid)
}
LIMIT 1000

@@join ?doi ?doi type=left
@@endpoint https://sparql.opencitations.net/meta
PREFIX datacite: <http://purl.org/spar/datacite/>
PREFIX literal:  <http://www.essepuntato.it/2010/06/literalreification/>

SELECT ?doi ?br WHERE {
  VALUES ?doi { [[dois]] }
  ?br datacite:hasIdentifier ?id .
  ?id datacite:usesIdentifierScheme datacite:doi ;
      literal:hasLiteralValue ?doi .
}

@@join ?br ?br type=left
@@endpoint https://sparql.opencitations.net/index
@@foreach ?br item wait=0.1
PREFIX cito: <http://purl.org/spar/cito/>

SELECT ?br (COUNT(?citing) AS ?oc_citation_count) WHERE {
  BIND(<[[item]]> AS ?br)
  ?cit a cito:Citation ;
       cito:hasCitedEntity  ?br ;
       cito:hasCitingEntity ?citing .
}
GROUP BY ?br

@@join ?doi ?doi type=left
@@endpoint sparql-anything
PREFIX fx:  <http://sparql.xyz/facade-x/ns/>
PREFIX xyz: <http://sparql.xyz/facade-x/data/>

SELECT ?doi ?title (MAX(?year0) AS ?year)
WHERE {
  VALUES ?doi { [[dois]] }
  BIND(
    fx:entity(
      "x-sparql-anything:media-type=application/json,location=https://api.crossref.org/works/",
      ?doi
    ) AS ?svc
  )

  SERVICE ?svc {
    # Crossref root → message object
    ?root xyz:message ?msg .

    # title is typically an array ["Title", ...]
    ?msg xyz:title ?titleArray .
    ?titleArray fx:anySlot ?title .

    # issued.date-parts is [[year, month]]; we just extract the first number
    ?msg xyz:issued ?issued .
    ?issued xyz:date-parts ?datePartsArray .
    ?datePartsArray fx:anySlot ?innerArray .
    ?innerArray fx:anySlot ?year0 .
  }
}
GROUP BY ?doi ?title