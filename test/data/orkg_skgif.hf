#url /skgif-orkg/v1
#type api
#base https://w3id.org/skg-if/sandbox/orkg
#title SKG-IF API for ORKG
#description SKG-IF compliant API exposing ORKG (Open Research Knowledge Graph) bibliographic data as JSON-LD, following the <a href="https://skg-if.github.io/interoperability-framework/" target="_blank">Scholarly Knowledge Graph Interoperability Framework specification</a>.
#html_meta_description SKG-IF API for ORKG: access bibliographic metadata via the Scholarly Knowledge Graph Interoperability Framework.
#version 0.1.0
#contacts <a href="mailto:contact@opencitations.net" target="_blank">contact@opencitations.net</a>
#license <a href="https://opensource.org/licenses/ISC" target="_blank">ISC</a>
#endpoint https://orkg.org/triplestore
#method post
#addon skgif_addon
#disable_params require,filter,sort,format,json

#url /products/{local_identifier}
#type operation
#local_identifier str(http://orkg\.org/orkg/resource/R\d+)
#method get
#description Returns a single research product from ORKG identified by its resource URI. The response includes bibliographic metadata (title, DOI, publication year, venue) and contributor information extracted from the ORKG triplestore.
#call /products/http://orkg.org/orkg/resource/R25543
#field_type str(local_identifier) str(identifier_scheme) str(identifier_value) str(title) str(title_lang) str(abstract) str(abstract_lang) str(product_type) str(topic_term) str(topic_identifier_scheme) str(topic_identifier_value) str(topic_label) str(topic_label_lang) str(topic_provenance_associated_with) str(topic_provenance_trust) str(contribution_by_family_name) str(contribution_by_given_name) str(contribution_by_name) str(contribution_by_identifier_scheme) str(contribution_by_identifier_value) str(contribution_by_local_identifier) str(contribution_role) str(contribution_type) str(_contribution_key) str(_contribution_next_key) str(contribution_declared_affiliation_name) str(contribution_declared_affiliation_short_name) str(contribution_declared_affiliation_country) str(contribution_declared_affiliation_local_identifier) str(contribution_declared_affiliation_identifier_scheme) str(contribution_declared_affiliation_identifier_value) str(contribution_declared_affiliation_type) str(contribution_declared_affiliation_website) str(contribution_declared_affiliation_other_name) str(manifestation_type_class) str(manifestation_type_label) str(manifestation_type_label_lang) str(manifestation_identifier_scheme) str(manifestation_identifier_value) str(manifestation_dates_type) str(manifestation_dates_value) str(manifestation_peer_review_status) str(manifestation_peer_review_description) str(manifestation_access_rights_status) str(manifestation_access_rights_description) str(manifestation_licence) str(manifestation_version) str(manifestation_biblio_volume) str(manifestation_biblio_issue) str(manifestation_biblio_edition) str(manifestation_biblio_number) str(manifestation_biblio_pages_first) str(manifestation_biblio_pages_last) str(manifestation_biblio_in_name) str(manifestation_biblio_in_local_identifier) str(manifestation_biblio_in_identifier_scheme) str(manifestation_biblio_in_identifier_value) str(manifestation_biblio_in_acronym) str(manifestation_biblio_hosting_data_source_local_identifier) str(manifestation_biblio_hosting_data_source_name) str(manifestation_biblio_hosting_data_source_identifier_scheme) str(manifestation_biblio_hosting_data_source_identifier_value) str(related_products_cites) str(related_products_is_supplemented_by) str(related_products_is_documented_by) str(related_products_is_new_version_of) str(related_products_is_part_of) str(funding_local_identifier) str(funding_grant_number) str(funding_title) str(funding_title_lang) str(funding_abstract) str(funding_abstract_lang) str(funding_acronym) str(funding_identifier_scheme) str(funding_identifier_value) str(funding_stream) str(funding_agency_name) str(funding_agency_short_name) str(funding_agency_country) str(funding_agency_local_identifier) str(funding_agency_identifier_scheme) str(funding_agency_identifier_value) str(funding_agency_type) str(funding_agency_website) str(relevant_organisation_name) str(relevant_organisation_short_name) str(relevant_organisation_country) str(relevant_organisation_local_identifier) str(relevant_organisation_identifier_scheme) str(relevant_organisation_identifier_value) str(relevant_organisation_type) str(relevant_organisation_website) str(relevant_organisation_other_name)
#format skgif,to_skgif
#default_format skgif
#sparql PREFIX orkgc: <http://orkg.org/orkg/class/>
PREFIX orkgp: <http://orkg.org/orkg/predicate/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?local_identifier ?identifier_scheme ?identifier_value
       ?title ?title_lang ?product_type
       ?manifestation_dates_type ?manifestation_dates_value
       ?manifestation_biblio_in_name ?manifestation_biblio_in_local_identifier
WHERE {
  BIND(<[[local_identifier]]> AS ?local_identifier)
  ?local_identifier a orkgc:Paper .
  OPTIONAL {
    ?local_identifier rdfs:label ?title_raw .
    BIND(STR(?title_raw) AS ?title)
    BIND(IF(LANG(?title_raw) != "", LANG(?title_raw), "") AS ?title_lang)
  }
  BIND("literature" AS ?product_type)
  OPTIONAL {
    ?local_identifier orkgp:P29 ?manifestation_dates_value .
    BIND("publication" AS ?manifestation_dates_type)
  }
  OPTIONAL {
    ?local_identifier orkgp:P26 ?doi_val .
    BIND("doi" AS ?identifier_scheme)
    BIND(?doi_val AS ?identifier_value)
  }
  OPTIONAL {
    ?local_identifier orkgp:HAS_VENUE ?venue_resource .
    ?venue_resource rdfs:label ?manifestation_biblio_in_name .
    BIND(STRAFTER(STR(?venue_resource), "http://orkg.org/orkg/resource/") AS ?manifestation_biblio_in_local_identifier)
  }
}

@@join ?local_identifier ?local_identifier type=left
PREFIX orkgp: <http://orkg.org/orkg/predicate/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?local_identifier ?contribution_by_name
       ?contribution_by_local_identifier ?contribution_role ?_contribution_key
WHERE {
  BIND(<[[local_identifier]]> AS ?local_identifier)
  ?local_identifier orkgp:hasAuthors ?authors .
  ?authors ?seq_pred ?author .
  FILTER(STRSTARTS(STR(?seq_pred), "http://www.w3.org/1999/02/22-rdf-syntax-ns#_"))
  BIND("author" AS ?contribution_role)
  ?author rdfs:label ?contribution_by_name .
  BIND(STRAFTER(STR(?author), "http://orkg.org/orkg/resource/") AS ?contribution_by_local_identifier)
  BIND(CONCAT(STR(?local_identifier), "/author/", STRAFTER(STR(?seq_pred), "http://www.w3.org/1999/02/22-rdf-syntax-ns#_")) AS ?_contribution_key)
}
ORDER BY xsd:integer(STRAFTER(STR(?seq_pred), "http://www.w3.org/1999/02/22-rdf-syntax-ns#_"))

@@join ?local_identifier ?local_identifier type=left
PREFIX orkgp: <http://orkg.org/orkg/predicate/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?local_identifier ?topic_term ?topic_label ?topic_label_lang
WHERE {
  BIND(<[[local_identifier]]> AS ?local_identifier)
  ?local_identifier orkgp:P30 ?field .
  BIND(STR(?field) AS ?topic_term)
  ?field rdfs:label ?topic_label_raw .
  BIND(STR(?topic_label_raw) AS ?topic_label)
  BIND(IF(LANG(?topic_label_raw) != "", LANG(?topic_label_raw), "") AS ?topic_label_lang)
}
