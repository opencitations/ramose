#url /skgif/v1
#type api
#base https://w3id.org/skg-if/sandbox/opencitations
#title SKG-IF API for OpenCitations
#description SKG-IF compliant API exposing OpenCitations bibliographic data as JSON-LD, following the [Scholarly Knowledge Graph Interoperability Framework specification](https://skg-if.github.io/interoperability-framework/).
#html_meta_description SKG-IF API for OpenCitations: access bibliographic metadata, citations, authors, and venues as JSON-LD via the Scholarly Knowledge Graph Interoperability Framework.
#version 1.0.0
#contacts [contact@opencitations.net](mailto:contact@opencitations.net)
#license [ISC](https://opensource.org/licenses/ISC)
#endpoint https://sparql.opencitations.net/meta
#method post
#sources meta=https://sparql.opencitations.net/meta;index=https://sparql.opencitations.net/index
#addon ramose.skg_if
#disable_params require,filter,sort,format,json

#url /products/{local_identifier}
#type operation
#local_identifier str(https://w3id\.org/oc/meta/.+)
#method get
#description Returns a single research product identified by its OpenCitations Meta identifier (OMID). The response includes bibliographic metadata from OpenCitations Meta and citation data from OpenCitations Index.
#call /products/https://w3id.org/oc/meta/br/062104388184
