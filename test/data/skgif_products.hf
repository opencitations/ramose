#url /topics
#type operation
#method get
#description Returns a list of topics matching the given filters. Note: OpenCitations does not currently hold topic data; this endpoint always returns an empty result.
#custom_params filter,handle_skgif_topic_filter,preprocess,Search filter.
Format: comma-separated <code>filter_name:filter_value</code> pairs (AND logic).
<br><br>
<strong>Accepted but always empty (OpenCitations does not hold topic data):</strong>
<ul>
  <li><code>cf.search.labels</code></li>
  <li><code>cf.search.language</code></li>
  <li><code>identifiers.scheme</code></li>
  <li><code>identifiers.value</code></li>
</ul>
#call /topics?filter=cf.search.labels:biology
#format skgif,to_skgif
#default_format skgif
#output_json {
    "@context": [
        "https://w3id.org/skg-if/context/1.1.0/skg-if.json",
