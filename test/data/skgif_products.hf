#url /datasources
#type operation
#method get
#description Returns a list of data sources matching the given filters. Note: OpenCitations does not currently hold data source records as standalone entities; this endpoint always returns an empty result.
#custom_params filter,handle_skgif_datasource_filter,preprocess,Search filter. Format: comma-separated filter_name:filter_value pairs (AND logic). Accepted but always empty (OpenCitations does not hold data source records): acronym, cf.search.name, data_source_classification, identifiers.scheme, identifiers.value, research_product_type
#call /datasources?filter=research_product_type:literature
#field_type str(dummy)
#output_json []
#sparql SELECT ?dummy WHERE { FILTER(false) [[filter]] }

#url /datasources/{local_identifier}
#type operation
#method get
#description Returns a single data source in SKG-IF JSON-LD format. Note: OpenCitations does not currently hold data source records as standalone entities; this endpoint always returns an empty graph.
#call /datasources/example-datasource-id
#field_type str(dummy)
#format skgif,to_skgif
#default_format skgif
#sparql SELECT ?dummy WHERE { FILTER(false) }
