#url /skgif/v1
#type api
#base https://w3id.org/skg-if/sandbox/opencitations
#title SKG-IF API for OpenCitations
#description SKG-IF compliant API exposing OpenCitations bibliographic data as JSON-LD, following the Scholarly Knowledge Graph Interoperability Framework specification.
#version 1.0.0
#contacts [contact@opencitations.net](mailto:contact@opencitations.net)
#license [ISC](https://opensource.org/licenses/ISC)
#endpoint https://sparql.opencitations.net/meta
#method post
#sources meta=https://sparql.opencitations.net/meta;index=https://sparql.opencitations.net/index
#addon skgif_addon
#disable_params require,filter,sort,format,json

#url /products
#type operation
#method get
#description Returns a list of research products matching the given filters.
#custom_params filter,handle_skgif_product_filter,preprocess,Search filter.
Format: comma-separated <code>filter_name:filter_value</code> pairs (AND logic).
<br><br>
<strong>Filters with data:</strong>
<ul>
  <li><code>cf.cited_by</code></li>
  <li><code>cf.cited_by_doi</code></li>
  <li><code>cf.cites</code></li>
  <li><code>cf.cites_doi</code></li>
  <li><code>cf.contributions_orcid</code></li>
  <li><code>cf.search.title</code></li>
  <li><code>contributions.by.family_name</code></li>
  <li><code>contributions.by.given_name</code></li>
  <li><code>contributions.by.identifiers.id</code></li>
  <li><code>contributions.by.identifiers.scheme</code></li>
  <li><code>contributions.by.local_identifier</code></li>
  <li><code>contributions.by.name</code></li>
  <li><code>identifiers.id</code></li>
  <li><code>identifiers.scheme</code></li>
  <li><code>product_type</code></li>
</ul>
<strong>Accepted but always empty (OpenCitations does not hold this data):</strong>
<ul>
  <li><code>cf.contributions_aff_country</code></li>
  <li><code>cf.contributions_aff_ror</code></li>
  <li><code>cf.search.title_abstract</code></li>
  <li><code>contributions.declared_affiliations.identifiers.id</code></li>
  <li><code>contributions.declared_affiliations.identifiers.scheme</code></li>
  <li><code>contributions.declared_affiliations.local_identifier</code></li>
  <li><code>contributions.declared_affiliations.name</code></li>
  <li><code>contributions.declared_affiliations.short_name</code></li>
  <li><code>funding.grant_number</code></li>
  <li><code>funding.identifiers.id</code></li>
  <li><code>funding.identifiers.scheme</code></li>
  <li><code>funding.local_identifier</code></li>
</ul>
#format skgif,to_skgif
#default_format skgif
#call /products?filter=cf.search.title:adaptive
#field_type str(br_uri) str(title)
#output_json [{"br_uri": "https://w3id.org/oc/meta/br/0612058700", "title": "Adaptive Environmental Management"}]
#sparql [[filter_preamble]]
PREFIX fabio: <http://purl.org/spar/fabio/>
PREFIX dcterm: <http://purl.org/dc/terms/>
PREFIX datacite: <http://purl.org/spar/datacite/>
PREFIX literal: <http://www.essepuntato.it/2010/06/literalreification/>
PREFIX pro: <http://purl.org/spar/pro/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

SELECT DISTINCT ?br_uri ?title
WHERE {
  ?br_uri a fabio:Expression ;
          dcterm:title ?title .
  [[filter]]
}
ORDER BY ?title

