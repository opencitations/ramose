#format skg_if,to_skg_if,application/ld+json
#default_format skg_if
#sparql PREFIX fabio: <http://purl.org/spar/fabio/>
PREFIX dcterm: <http://purl.org/dc/terms/>
PREFIX prism: <http://prismstandard.org/namespaces/basic/2.0/>
PREFIX frbr: <http://purl.org/vocab/frbr/core#>
PREFIX datacite: <http://purl.org/spar/datacite/>
PREFIX literal: <http://www.essepuntato.it/2010/06/literalreification/>

SELECT ?local_identifier ?identifier_scheme ?identifier_value
       ?title ?product_type
       ?manifestation_type_class ?manifestation_type_label ?manifestation_type_label_lang
       ?manifestation_dates_type ?manifestation_dates_value
       ?manifestation_biblio_volume ?manifestation_biblio_issue
       ?manifestation_biblio_pages_first ?manifestation_biblio_pages_last
       ?manifestation_biblio_in_name ?manifestation_biblio_in_local_identifier
       ?manifestation_biblio_in_identifier_scheme ?manifestation_biblio_in_identifier_value
WHERE {
  BIND(<[[local_identifier]]> AS ?local_identifier)
  ?local_identifier a fabio:Expression .
  OPTIONAL { ?local_identifier dcterm:title ?title }
  OPTIONAL { ?local_identifier a ?manifestation_type_class . FILTER(?manifestation_type_class != fabio:Expression) }
  BIND(IF(!BOUND(?manifestation_type_class), "literature", IF(?manifestation_type_class IN (<http://purl.org/spar/fabio/DataFile>, <http://purl.org/spar/fabio/DataManagementPlan>), "research data", IF(?manifestation_type_class = <http://purl.org/spar/fabio/ComputerProgram>, "research software", "literature"))) AS ?product_type)
  BIND(IF(BOUND(?manifestation_type_class), LCASE(REPLACE(REPLACE(STR(?manifestation_type_class), "^.*[/#]", ""), "([a-z])([A-Z])", "$1 $2")), "") AS ?manifestation_type_label)
  BIND(IF(BOUND(?manifestation_type_class), "en", "") AS ?manifestation_type_label_lang)
  OPTIONAL {
    ?local_identifier prism:publicationDate ?manifestation_dates_value .
    BIND("publication" AS ?manifestation_dates_type)
  }
  OPTIONAL {
    ?local_identifier frbr:embodiment ?resource_embodiment .
    ?resource_embodiment prism:startingPage ?manifestation_biblio_pages_first ;
                         prism:endingPage ?manifestation_biblio_pages_last .
  }
  OPTIONAL {
    ?local_identifier frbr:partOf ?journal_issue .
    ?journal_issue a fabio:JournalIssue ;
                   fabio:hasSequenceIdentifier ?manifestation_biblio_issue .
  }
  OPTIONAL {
    ?local_identifier frbr:partOf+ ?journal_volume .
    ?journal_volume a fabio:JournalVolume ;
                    fabio:hasSequenceIdentifier ?manifestation_biblio_volume .
  }
  OPTIONAL {
    ?local_identifier datacite:hasIdentifier ?identifier_node .
    ?identifier_node datacite:usesIdentifierScheme ?identifier_scheme_uri ;
                     literal:hasLiteralValue ?identifier_value .
    BIND(STRAFTER(STR(?identifier_scheme_uri), "http://purl.org/spar/datacite/") AS ?identifier_scheme)
  }
  OPTIONAL {
    {
      ?local_identifier a fabio:JournalArticle ;
              frbr:partOf+ ?venue_resource .
      ?venue_resource a fabio:Journal .
    } UNION {
      ?local_identifier frbr:partOf ?venue_resource .
      FILTER NOT EXISTS { ?venue_resource a fabio:JournalIssue }
      FILTER NOT EXISTS { ?venue_resource a fabio:JournalVolume }
    }
    ?venue_resource dcterm:title ?manifestation_biblio_in_name .
    BIND(STR(?venue_resource) AS ?manifestation_biblio_in_local_identifier)
    OPTIONAL {
      ?venue_resource datacite:hasIdentifier ?venue_identifier_node .
      ?venue_identifier_node datacite:usesIdentifierScheme ?venue_identifier_scheme_uri ;
                     literal:hasLiteralValue ?manifestation_biblio_in_identifier_value .
      BIND(STRAFTER(STR(?venue_identifier_scheme_uri), "http://purl.org/spar/datacite/") AS ?manifestation_biblio_in_identifier_scheme)
    }
  }
}

@@join ?local_identifier ?local_identifier type=left
PREFIX pro: <http://purl.org/spar/pro/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX datacite: <http://purl.org/spar/datacite/>
PREFIX literal: <http://www.essepuntato.it/2010/06/literalreification/>
PREFIX oco: <https://w3id.org/oc/ontology/>

SELECT ?local_identifier ?contribution_by_family_name ?contribution_by_given_name
       ?contribution_by_name ?contribution_by_identifier_scheme ?contribution_by_identifier_value
       ?contribution_by_local_identifier
       ?contribution_role ?_contribution_key ?_contribution_next_key
WHERE {
  BIND(<[[local_identifier]]> AS ?local_identifier)
  ?local_identifier pro:isDocumentContextFor ?agent_role .
  ?agent_role pro:withRole ?role_type ;
              pro:isHeldBy ?responsible_agent .
  FILTER(?role_type IN (pro:author, pro:editor, pro:publisher))
  BIND(IF(?role_type = pro:author, "author", IF(?role_type = pro:editor, "editor", "publisher")) AS ?contribution_role)
  BIND(STR(?agent_role) AS ?_contribution_key)
  OPTIONAL {
    ?agent_role oco:hasNext ?next_agent_role .
    BIND(STR(?next_agent_role) AS ?_contribution_next_key)
  }
  OPTIONAL { ?responsible_agent foaf:familyName ?contribution_by_family_name }
  OPTIONAL { ?responsible_agent foaf:givenName ?contribution_by_given_name }
  OPTIONAL { ?responsible_agent foaf:name ?contribution_by_name }
  BIND(STR(?responsible_agent) AS ?contribution_by_local_identifier)
  OPTIONAL {
    ?responsible_agent datacite:hasIdentifier ?orcid_node .
    ?orcid_node datacite:usesIdentifierScheme datacite:orcid ;
                literal:hasLiteralValue ?contribution_by_identifier_value .
    BIND("orcid" AS ?contribution_by_identifier_scheme)
  }
}

@@join ?local_identifier ?local_identifier type=left
@@with source=index
PREFIX cito: <http://purl.org/spar/cito/>

SELECT ?local_identifier ?related_products_cites
WHERE {
  BIND(<[[local_identifier]]> AS ?citing_entity)
  ?citation cito:hasCitingEntity ?citing_entity ;
            cito:hasCitedEntity ?cited_entity .
  BIND(STR(?citing_entity) AS ?local_identifier)
  BIND(STR(?cited_entity) AS ?related_products_cites)
}

#url /products
#type operation
#method get
#description Returns a list of research products matching the given filters.
#custom_params filter,skgif_filters.ocdm.yaml,Search filter.
Format: comma-separated `filter_name:filter_value` pairs (AND logic).
Filters in the first group use exact matching. For `cf.search.*`, matching is text contains.
Filters marked as currently empty are accepted but return no matches in OpenCitations at the moment.

**Attribute filters:**

- `product_type`
- `identifiers.id`
- `identifiers.scheme`
- `contributions.by.local_identifier`
- `contributions.by.identifiers.id`
- `contributions.by.identifiers.scheme`
- `contributions.by.family_name`
- `contributions.by.given_name`
- `contributions.by.name`
- `contributions.declared_affiliations.local_identifier` (currently empty)
- `contributions.declared_affiliations.identifiers.id` (currently empty)
- `contributions.declared_affiliations.identifiers.scheme` (currently empty)
- `contributions.declared_affiliations.name` (currently empty)
- `contributions.declared_affiliations.short_name` (currently empty)
- `funding.local_identifier` (currently empty)
- `funding.grant_number` (currently empty)
- `funding.identifiers.id` (currently empty)
- `funding.identifiers.scheme` (currently empty)

**Convenience filters (`cf.*`):**

- `cf.search.title`
- `cf.search.title_abstract` (currently empty)
- `cf.contributions_orcid`
- `cf.contributions_aff_ror` (currently empty)
- `cf.contributions_aff_country` (currently empty)
- `cf.cites`
- `cf.cited_by`
- `cf.cites_doi`
- `cf.cited_by_doi`
