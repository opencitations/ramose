#url /skgif-test/v1
#type api
#base http://localhost:5000
#endpoint http://localhost:9999/sparql
#title SKG-IF Like API
#version 0.1.0
#disable_params require,filter,sort,format,json

#url /products/{local_id}
#type operation
#local_id str(R\d+)
#method get
#description Returns a single product.
#format skg_if,to_skg_if,application/ld+json
#default_format skg_if
#call /products/R42
#output_json {"@context": ["https://example.org/ctx.json", {"@base": "https://example.org/"}], "meta": {"total_items": 1}, "@graph": [{"local_identifier": "R42", "title": "Test", "score": 0.95, "published": true}]}
#sparql SELECT ?local_id WHERE { BIND("test" AS ?local_id) }
